{
  "cl": {
    "prefix": "cl",
    "body": [
      "local ${1:Obj} = {}",
      "$1.__index = $1",
      "",
      "function $1.new($2)",
      "\tlocal self = setmetatable({$3}, $1)",
      "\t$0",
      "\treturn self",
      "end"
    ],
    "description": "create a Lua class"
  },
  "method": {
    "prefix": ["met", "fum"],
    "body": ["function {$1:Obj}:${2:methodName}($3)", "\t$0", "end"],
    "description": "method for a class"
  },
  "lafu": {
    "prefix": "lafu",
    "body": ["local ${1:name} = function($2)", "\t${0}", "end"],
    "description": "local assignment function"
  },
  "afu": {
    "prefix": "afu",
    "body": ["${1:name} = function($2)", "\t${0}", "end"],
    "description": "assignment function"
  },
  "a": {
    "prefix": "a",
    "body": ["${1:name} = ${2:nil}"],
    "description": "assignment"
  },
  "la": {
    "prefix": "la",
    "body": ["local ${1:name} = ${2:nil}"],
    "description": "local assignment"
  },
  "lpca": {
    "prefix": "lpca",
    "body": ["local ${1:ok}, ${2:err} = pcall($3)"],
    "description": "local pcall"
  },
  "lreq": {
    "prefix": "lreq",
    "body": ["local ${1:module} = require('${2}')$0"],
    "description": "local require"
  },
  "lm": {
    "prefix": "lm",
    "body": ["local ${1:M} = {}", "$0", "return $1"],
    "description": "local module"
  },
  "forn": {
    "prefix": "forn",
    "body": ["for i = ${1:1}, ${2:n}, ${3:1} do", "\t$0", "end"],
    "description": "numeric for"
  }
}
